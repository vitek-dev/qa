<?xml version="1.0"?>
<ruleset name="Coding standard">
    <rule ref="VitekDevCodingStandard"/>

    <file>src</file>

    <exclude-pattern>*/vendor/*</exclude-pattern>

    <extensions>
        <extension name="php"/>
    </extensions>

    <arg name="severity" value="2"/>
    <arg name="tab-width" value="4"/>
</ruleset>
